{
  "schemaVersion": 1,
  "id": "blockboy-arcade",
  "version": "${version}",
  "name": "BlockBoy",
  "description": "Data-driven Gameboy Arcades for your fabric minecraft server!",
  "authors": [
    "tomalbrc"
  ],
  "contact": {
    "website": "https://github.com/tomalbrc/BlockBoyArcade",
    "repo": "https://github.com/tomalbrc/BlockBoyArcade"
  },
  "license": "MIT",
  "icon": "blockboy-arcade-icon@1024.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "de.tomalbrc.blockboy_arcade.BlockBoyArcade"
    ],
    "voicechat": [
      "de.tomalbrc.blockboy_arcade.voicechat.SVCPlugin"
    ]
  },
  "mixins": [
    "blockboy-arcade.mixins.json"
  ],
  "accessWidener": "blockboy_arcade.accesswidener",
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric": "*",
    "filament": ">=0.17.1",
    "minecraft": ">=${minecraft_version}"
  }
}
